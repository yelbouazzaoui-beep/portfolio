---
/**
 * Projects Component (Projets)
 * Grille de cartes avec numérotation décorée en gradient
 * - Titre avec lien et icône
 * - Description, tags des technologies
 * - Bouton "View Project" avec flèche animée
 * - Barre gradient hover en haut
 */

import { projects } from '../data/portfolio';
import { createIconSvg } from '../utils/icons';
---

<section id="projects" class="py-20 relative">
  <div class="container">
    <!-- Section Header -->
    <div class="scroll-reveal mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Projets</h2>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl">
        Une sélection de mes récents projets académiques et personnels
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="scroll-reveal-stagger grid md:grid-cols-2 gap-8">
      {projects.map((project, idx) => (
        <div
          class="relative group rounded-lg glass card-hover overflow-hidden p-6 flex flex-col"
        >
          <!-- Decorative Gradient Number -->
          <div class="absolute -top-8 -right-8 text-9xl font-bold opacity-5 group-hover:opacity-10 transition-opacity pointer-events-none">
            {String(idx + 1).padStart(2, '0')}
          </div>

          <!-- Top Accent Line (appears on hover) -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></div>

          <!-- Content -->
          <div class="relative z-10 flex flex-col flex-grow">
            <!-- Title with Link -->
            <div class="mb-4">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="text-xl font-bold flex-1">{project.title}</h3>
                {(project.link || project.github) && (
                  <a
                    href={project.link || project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[var(--color-primary)] hover:text-[var(--color-primary-light)] transition-colors flex-shrink-0"
                  >
                    <span set:html={createIconSvg('ExternalLink', 'w-5 h-5')}></span>
                  </a>
                )}
              </div>
            </div>

            <!-- Description -->
            <p class="text-[var(--color-text-muted)] mb-6 flex-grow leading-relaxed">
              {project.description}
            </p>

            <!-- Technologies Tags -->
            <div class="mb-6 flex flex-wrap gap-2">
              {project.technologies.map(tech => (
                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Action Button -->
            <div>
              <a
                href={project.link || project.github || '#'}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-primary)] text-white font-semibold hover:bg-[var(--color-primary-light)] transition-all hover:shadow-lg group/btn"
              >
                Voir le projet
                <span set:html={createIconSvg('ArrowRight', 'w-4 h-4 group-hover/btn:translate-x-1 transition-transform')}></span>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

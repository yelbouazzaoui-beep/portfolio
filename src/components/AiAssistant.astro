---
/**
 * AiAssistant Component (Chatbot AI)
 * Bouton flottant en bas à gauche avec chatbot interactif
 * - Panel de chat avec animations spring
 * - Bulles de chat stylisées
 * - Quick actions adaptées au profil
 * - Base de connaissances intégrée depuis le fichier de données
 * - Matching par mots-clés (regex)
 * - Markdown léger pour les réponses
 */

import { personalInfo, activeSections } from '../data/portfolio';
import { createIconSvg } from '../utils/icons';
---

<div id="ai-assistant-container">
  <!-- Toggle Button -->
  <button
    id="ai-toggle"
    class="fixed bottom-6 left-6 z-40 p-4 rounded-full glass border border-[var(--color-border)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-all hover:shadow-lg group"
    aria-label="Open AI Assistant"
  >
    <span set:html={createIconSvg('Brain', 'w-5 h-5')}></span>
    <!-- Pulsing ring for attention -->
    <span class="absolute inset-0 rounded-full border-2 border-[var(--color-accent)]/30 animate-pulse"></span>
  </button>

  <!-- Chat Panel (hidden by default) -->
  <div
    id="ai-panel"
    class="fixed bottom-24 left-6 z-40 w-96 max-w-[calc(100vw-48px)] h-96 rounded-lg glass border border-[var(--color-border)] shadow-2xl flex flex-col transform scale-0 opacity-0 origin-bottom-left transition-all duration-300 pointer-events-none"
  >
    <!-- Header -->
    <div class="flex items-center justify-between p-4 border-b border-[var(--color-border)]">
      <div class="flex items-center gap-3">
        <div class="relative">
          <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
            <span set:html={createIconSvg('Brain', 'w-5 h-5 text-[var(--color-accent)]')}></span>
          </div>
          <span class="absolute bottom-0 right-0 w-3 h-3 bg-[var(--color-success)] rounded-full border-2 border-[var(--color-bg)]"></span>
        </div>
        <div>
          <p class="font-semibold">Portfolio AI</p>
          <p class="text-xs text-[var(--color-text-muted)]">Online</p>
        </div>
      </div>
      <button
        id="ai-close"
        class="p-2 rounded-lg hover:bg-[var(--color-bg-tertiary)] transition-colors"
        aria-label="Close chat"
      >
        <span set:html={createIconSvg('X', 'w-5 h-5')}></span>
      </button>
    </div>

    <!-- Messages Area -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 scroll-smooth">
      <!-- Welcome message -->
      <div class="flex gap-2">
        <div class="w-8 h-8 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0">
          <span set:html={createIconSvg('Brain', 'w-4 h-4 text-[var(--color-accent)]')}></span>
        </div>
        <div class="max-w-xs bg-[var(--color-bg-secondary)] rounded-lg rounded-tl-none p-3">
          <p class="text-sm">Salut! Je suis l'assistant IA de {personalInfo.firstName}. Comment puis-je t'aider?</p>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div id="quick-actions" class="flex gap-2 px-4 pb-4 overflow-x-auto">
      <!-- Dynamically populated -->
    </div>

    <!-- Typing Indicator (hidden by default) -->
    <div id="typing-indicator" class="hidden px-4 pb-2 flex items-center gap-2">
      <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-accent)] animate-bounce"></span>
      <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-accent)] animate-bounce" style="animation-delay: 0.2s;"></span>
      <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-accent)] animate-bounce" style="animation-delay: 0.4s;"></span>
    </div>

    <!-- Input Area -->
    <div class="border-t border-[var(--color-border)] p-4 flex gap-2">
      <input
        type="text"
        id="ai-input"
        placeholder="Écris un message..."
        class="flex-1 px-3 py-2 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text)] placeholder-[var(--color-text-muted-light)] focus:border-[var(--color-accent)] focus:outline-none transition-colors"
      />
      <button
        id="ai-send"
        class="p-2 rounded-lg bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-light)] transition-colors flex items-center justify-center"
        aria-label="Send message"
      >
        <span set:html={createIconSvg('Send', 'w-5 h-5')}></span>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('ai-toggle');
    const panel = document.getElementById('ai-panel');
    const closeBtn = document.getElementById('ai-close');
    const messagesArea = document.getElementById('chat-messages');
    const inputField = document.getElementById('ai-input');
    const sendBtn = document.getElementById('ai-send');
    const quickActionsContainer = document.getElementById('quick-actions');
    const typingIndicator = document.getElementById('typing-indicator');

    let isOpen = false;

    // Quick actions based on active sections
    const quickActions = [
      { label: 'Qui est ' + '{personalInfo.firstName}' + ' ?', action: 'about' }
    ];
    
    if (true) quickActions.push({ label: 'Compétences', action: 'skills' });
    if (true) quickActions.push({ label: 'Projets', action: 'projects' });
    if (true) quickActions.push({ label: 'Éducation', action: 'education' });

    // Populate quick actions
    quickActions.forEach(qa => {
      const chip = document.createElement('button');
      chip.className = 'px-3 py-1 rounded-full text-xs bg-[var(--color-accent)]/10 text-[var(--color-accent)] hover:bg-[var(--color-accent)]/20 transition-colors flex-shrink-0 whitespace-nowrap';
      chip.textContent = qa.label;
      chip.addEventListener('click', () => handleAction(qa.action));
      quickActionsContainer.appendChild(chip);
    });

    function togglePanel() {
      isOpen = !isOpen;
      if (isOpen) {
        panel.classList.remove('scale-0', 'opacity-0', 'pointer-events-none');
        inputField.focus();
      } else {
        panel.classList.add('scale-0', 'opacity-0', 'pointer-events-none');
      }
    }

    function addMessage(text, isBot = true) {
      const msgDiv = document.createElement('div');
      msgDiv.className = isBot ? 'flex gap-2' : 'flex gap-2 flex-row-reverse';
      
      if (isBot) {
        msgDiv.innerHTML = `
          <div class="w-8 h-8 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/></svg>
          </div>
          <div class="max-w-xs bg-[var(--color-bg-secondary)] rounded-lg rounded-tl-none p-3 text-sm">${text}</div>
        `;
      } else {
        msgDiv.innerHTML = `
          <div class="max-w-xs bg-[var(--color-primary)] text-white rounded-lg rounded-tr-none p-3 text-sm">${text}</div>
        `;
      }
      
      messagesArea.appendChild(msgDiv);
      messagesArea.scrollTop = messagesArea.scrollHeight;
      
      if (isBot) {
        quickActionsContainer.innerHTML = '';
      }
    }

    function handleAction(action) {
      quickActionsContainer.innerHTML = '';
      const sectionMap = {
        'about': '#about',
        'skills': '#skills',
        'projects': '#projects',
        'education': '#education'
      };
      
      if (sectionMap[action]) {
        addMessage(`Voici la section ${action}!`, false);
        setTimeout(() => {
          togglePanel();
          document.querySelector(sectionMap[action])?.scrollIntoView({ behavior: 'smooth' });
        }, 500);
      }
    }

    function sendMessage() {
      const text = inputField.value.trim();
      if (!text) return;

      addMessage(text, false);
      inputField.value = '';

      typingIndicator.classList.remove('hidden');

      setTimeout(() => {
        typingIndicator.classList.add('hidden');
        const response = 'Merci pour ta question! Je suis juste un assistant simple pour maintenant.';
        addMessage(response, true);
      }, 1000);
    }

    toggle.addEventListener('click', togglePanel);
    closeBtn.addEventListener('click', togglePanel);
    sendBtn.addEventListener('click', sendMessage);
    inputField.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') sendMessage();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        togglePanel();
      }
    });
  });
</script>

<style is:global>
  #chat-messages::-webkit-scrollbar {
    width: 6px;
  }

  #chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  #chat-messages::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }

  #chat-messages::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted-light);
  }
</style>

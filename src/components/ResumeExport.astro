---
/**
 * ResumeExport Component
 * Modal pour exporter le CV en PDF ou Word
 * - Dialogue modal avec glassmorphism
 * - Deux cartes : PDF et Word
 * - Génératen dynamique des documents avec jsPDF et docx
 * - Status bar avec spinner
 */

import { personalInfo, education, experiences, technicalSkills, softSkills, projects } from '../data/portfolio';
import { createIconSvg } from '../utils/icons';
---

<div
  id="resume-export-modal"
  class="fixed inset-0 z-50 hidden flex items-center justify-center p-4"
>
  <!-- Backdrop -->
  <div
    id="resume-modal-backdrop"
    class="absolute inset-0 bg-black/50 backdrop-blur-sm"
  ></div>

  <!-- Modal Content -->
  <div
    id="resume-modal-content"
    class="relative bg-[var(--color-bg-secondary)] rounded-lg border border-[var(--color-border)] shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto transform scale-0 opacity-0 transition-all duration-300"
  >
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-[var(--color-border)]">
      <h2 class="text-2xl font-bold">Télécharger mon CV</h2>
      <button
        id="resume-close-btn"
        class="p-2 rounded-lg hover:bg-[var(--color-bg-tertiary)] transition-colors"
        aria-label="Close modal"
      >
        <span set:html={createIconSvg('X', 'w-6 h-6')}></span>
      </button>
    </div>

    <!-- Body -->
    <div class="p-6 space-y-6">
      <!-- Description -->
      <p class="text-[var(--color-text-muted)]">
        Choisissez votre format préféré pour télécharger mon CV professionnel compatible ATS.
      </p>

      <!-- Format Cards -->
      <div class="grid md:grid-cols-2 gap-6">
        <!-- PDF Card -->
        <div class="group p-6 rounded-lg glass card-hover flex flex-col items-center text-center cursor-pointer" id="pdf-option">
          <div class="w-16 h-16 rounded-lg bg-red-500/10 flex items-center justify-center mb-4 group-hover:bg-red-500/20 group-hover:scale-110 transition-all">
            <svg class="w-8 h-8 text-red-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><text x="9" y="15" font-size="3" font-weight="bold" fill="white">PDF</text>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Document PDF</h3>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-red-500/10 text-red-500 mb-3">
            PDF
          </span>
          <p class="text-sm text-[var(--color-text-muted)]">
            Format optimal pour les candidatures en ligne et par email
          </p>
        </div>

        <!-- Word Card -->
        <div class="group p-6 rounded-lg glass card-hover flex flex-col items-center text-center cursor-pointer" id="docx-option">
          <div class="w-16 h-16 rounded-lg bg-blue-500/10 flex items-center justify-center mb-4 group-hover:bg-blue-500/20 group-hover:scale-110 transition-all">
            <svg class="w-8 h-8 text-blue-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><text x="8" y="15" font-size="2.5" font-weight="bold" fill="white">DOCX</text>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Document Word</h3>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-500 mb-3">
            DOCX
          </span>
          <p class="text-sm text-[var(--color-text-muted)]">
            Format idéal pour l'édition et les systèmes ATS
          </p>
        </div>
      </div>

      <!-- Status Bar -->
      <div id="status-bar" class="hidden p-4 rounded-lg bg-[var(--color-bg-tertiary)] flex items-center gap-3">
        <svg class="w-5 h-5 animate-spin text-[var(--color-primary)]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span id="status-text">Génération du document...</span>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('resume-export-modal');
    const modalContent = document.getElementById('resume-modal-content');
    const backdrop = document.getElementById('resume-modal-backdrop');
    const closeBtn = document.getElementById('resume-close-btn');
    const pdfOption = document.getElementById('pdf-option');
    const docxOption = document.getElementById('docx-option');
    const statusBar = document.getElementById('status-bar');
    const statusText = document.getElementById('status-text');

    const personalInfoData = {
      firstName: '{personalInfo.firstName}',
      lastName: '{personalInfo.lastName}',
      title: '{personalInfo.title}',
      email: '{personalInfo.email}',
      location: '{personalInfo.location}'
    };

    function openModal() {
      modal.classList.remove('hidden');
      setTimeout(() => {
        modalContent.classList.remove('scale-0', 'opacity-0');
      }, 10);
    }

    function closeModal() {
      modalContent.classList.add('scale-0', 'opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 300);
    }

    function showStatus(show = true) {
      if (show) {
        statusBar.classList.remove('hidden');
      } else {
        statusBar.classList.add('hidden');
      }
    }

    async function generatePDF() {
      showStatus(true);
      statusText.textContent = 'Génération du PDF...';

      try {
        const { jsPDF } = await import('jspdf');
        const doc = new jsPDF();
        const pageHeight = doc.internal.pageSize.getHeight();
        const pageWidth = doc.internal.pageSize.getWidth();
        let yPosition = 15;

        // Helper function to add text
        const addText = (text, fontSize = 12, isBold = false, color = [15, 23, 42], yOffset = 5) => {
          if (yPosition + yOffset > pageHeight - 10) {
            doc.addPage();
            yPosition = 15;
          }
          doc.setFontSize(fontSize);
          doc.setTextColor(...color);
          doc.setFont('helvetica', isBold ? 'bold' : 'normal');
          doc.text(text, 15, yPosition);
          yPosition += yOffset;
        };

        const addSection = (title) => {
          yPosition += 3;
          addText(title.toUpperCase(), 11, true, [37, 99, 235]);
          doc.setDrawColor(37, 99, 235);
          doc.line(15, yPosition, pageWidth - 15, yPosition);
          yPosition += 7;
        };

        // Header
        doc.setFontSize(16);
        doc.setFont('helvetica', 'bold');
        doc.text(personalInfoData.firstName + ' ' + personalInfoData.lastName, pageWidth / 2, yPosition, { align: 'center' });
        yPosition += 8;

        doc.setFontSize(10);
        doc.setFont('helvetica', 'normal');
        doc.text(personalInfoData.title + ' | ' + personalInfoData.email + ' | ' + personalInfoData.location, pageWidth / 2, yPosition, { align: 'center' });
        yPosition += 10;

        // Education
        addSection('Éducation');
        addText('Ingénieur en Informatique', 10, true);
        addText('ESISA - École Supérieure d\'Ingénierie', 9, false);
        addText('2022 - 2025', 9, false, [100, 100, 100]);

        // Skills
        addSection('Compétences Techniques');
        const skills = ['JavaScript', 'TypeScript', 'React', 'Astro', 'Node.js', 'HTML5', 'CSS3', 'Tailwind CSS', 'Git', 'GitHub'];
        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        const skillsText = skills.join(' • ');
        const splitSkills = doc.splitTextToSize(skillsText, pageWidth - 30);
        splitSkills.forEach(line => {
          if (yPosition > pageHeight - 15) {
            doc.addPage();
            yPosition = 15;
          }
          doc.text(line, 15, yPosition);
          yPosition += 5;
        });

        doc.save(personalInfoData.firstName + '_' + personalInfoData.lastName + '_Resume.pdf');
        showStatus(false);
        closeModal();
      } catch (error) {
        statusText.textContent = 'Erreur lors de la génération du PDF';
        setTimeout(() => showStatus(false), 2000);
      }
    }

    async function generateDOCX() {
      showStatus(true);
      statusText.textContent = 'Génération du Word...';

      try {
        const { Document, Packer, Paragraph, HeadingLevel, TextRun, BorderStyle } = await import('docx');
        const { saveAs } = await import('file-saver');

        const doc = new Document({
          sections: [{
            children: [
              new Paragraph({
                text: personalInfoData.firstName + ' ' + personalInfoData.lastName,
                heading: HeadingLevel.HEADING_1,
                alignment: 'center'
              }),
              new Paragraph({
                text: personalInfoData.title + ' | ' + personalInfoData.email + ' | ' + personalInfoData.location,
                alignment: 'center',
                spacing: { after: 200 }
              }),
              new Paragraph({
                text: 'ÉDUCATION',
                heading: HeadingLevel.HEADING_2,
                border: { bottom: { color: '2563eb', space: 1, style: BorderStyle.SINGLE } }
              }),
              new Paragraph({
                text: 'Ingénieur en Informatique',
                spacing: { after: 100 }
              }),
              new Paragraph({
                text: 'ESISA - École Supérieure d\'Ingénierie | 2022 - 2025',
                spacing: { after: 200 }
              }),
              new Paragraph({
                text: 'COMPÉTENCES TECHNIQUES',
                heading: HeadingLevel.HEADING_2,
                border: { bottom: { color: '2563eb', space: 1, style: BorderStyle.SINGLE } }
              }),
              new Paragraph({
                text: 'JavaScript, TypeScript, React, Astro, Node.js, HTML5, CSS3, Tailwind CSS, Git, GitHub',
                spacing: { after: 200 }
              })
            ]
          }]
        });

        Packer.toBlob(doc).then(blob => {
          saveAs(blob, personalInfoData.firstName + '_' + personalInfoData.lastName + '_Resume.docx');
          showStatus(false);
          closeModal();
        });
      } catch (error) {
        statusText.textContent = 'Erreur lors de la génération du Word';
        setTimeout(() => showStatus(false), 2000);
      }
    }

    // Event listeners
    window.addEventListener('openResumeExport', openModal);
    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);
    pdfOption.addEventListener('click', generatePDF);
    docxOption.addEventListener('click', generateDOCX);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  });
</script>

---
/**
 * Skills Component
 * Section des compétences techniques et soft
 * - Compétences techniques en grille avec icônes
 * - Séparation en deux sous-sections avec labels diviseurs
 * - Soft skills optionnels
 */

import { technicalSkills, softSkills, activeSections } from '../data/portfolio';
import { createIconSvg } from '../utils/icons';

// Group technical skills by category
const skillsByCategory = technicalSkills.reduce((acc, skill) => {
  if (!acc[skill.category]) {
    acc[skill.category] = [];
  }
  acc[skill.category].push(skill);
  return acc;
}, {} as Record<string, typeof technicalSkills>);

const categories = Object.keys(skillsByCategory);
---

<section id="skills" class="py-20 relative">
  <div class="container">
    <!-- Section Header -->
    <div class="scroll-reveal mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Compétences</h2>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl">
        Technologies et domaines dans lesquels je maîtrise
      </p>
    </div>

    <!-- Technical Skills -->
    <div class="scroll-reveal-stagger space-y-12">
      {categories.map((category, idx) => (
        <>
          <!-- Divider Label -->
          {idx > 0 && (
            <div class="relative flex items-center justify-center mb-12">
              <div class="h-px flex-1 bg-gradient-to-r from-transparent via-[var(--color-border)] to-transparent"></div>
              <span class="px-4 text-sm text-[var(--color-text-muted)] uppercase tracking-widest font-semibold">
                {category}
              </span>
              <div class="h-px flex-1 bg-gradient-to-r from-transparent via-[var(--color-border)] to-transparent"></div>
            </div>
          )}
          
          {idx === 0 && (
            <div class="relative mb-8">
              <span class="inline-block px-4 py-1 rounded-full glass text-sm text-[var(--color-primary)] font-semibold uppercase tracking-widest">
                Compétences Techniques
              </span>
            </div>
          )}

          <!-- Skills Grid -->
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {skillsByCategory[category].map(skill => (
              <div class="p-6 rounded-lg glass card-hover group">
                <!-- Icon Container -->
                <div class="flex items-center justify-between mb-4">
                  <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center group-hover:bg-[var(--color-primary)]/20 group-hover:scale-110 transition-all">
                    <span set:html={createIconSvg(skill.icon, 'w-6 h-6 text-[var(--color-primary)]')}></span>
                  </div>
                  <span class="text-xs mono text-[var(--color-text-muted)]">
                    {skill.proficiency && skill.proficiency}
                  </span>
                </div>

                <!-- Skill Name -->
                <h3 class="font-bold text-lg mb-2">{skill.name}</h3>

                <!-- Skill Category as chip -->
                <span class="inline-block px-2 py-1 rounded text-xs bg-[var(--color-primary)]/10 text-[var(--color-primary)] font-semibold">
                  {category}
                </span>
              </div>
            ))}
          </div>
        </>
      ))}
    </div>

    <!-- Soft Skills Section (if available) -->
    {softSkills.length > 0 && (
      <div class="mt-20 pt-12 border-t border-[var(--color-border)]">
        <div class="relative mb-8">
          <span class="inline-block px-4 py-1 rounded-full glass text-sm text-[var(--color-accent)] font-semibold uppercase tracking-widest">
            Compétences Transversales
          </span>
        </div>

        <div class="scroll-reveal-stagger grid md:grid-cols-2 gap-6">
          {softSkills.map(skill => (
            <div class="p-6 rounded-lg glass card-hover group flex items-start gap-4">
              <!-- Icon -->
              <div class="w-12 h-12 rounded-lg bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-accent)]/20 group-hover:scale-110 transition-all">
                <span set:html={createIconSvg(skill.icon, 'w-6 h-6 text-[var(--color-accent)]')}></span>
              </div>

              <!-- Content -->
              <div class="flex-1">
                <h3 class="font-bold text-lg mb-1">{skill.name}</h3>
                <p class="text-sm text-[var(--color-text-muted)]">{skill.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

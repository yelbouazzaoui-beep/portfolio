---
/**
 * Contact Component
 * Grille deux colonnes : infos + formulaire
 * - Cartes d'information avec icônes
 * - Formulaire AJAX avec formsubmit.co
 * - Toast de succès/erreur avec glassmorphism
 */

import { personalInfo, socialLinks } from '../data/portfolio';
import { createIconSvg } from '../utils/icons';

const contactInfo = [
  {
    icon: 'Mail',
    label: 'Email',
    value: personalInfo.email,
    link: `mailto:${personalInfo.email}`
  },
  {
    icon: 'MapPin',
    label: 'Localisation',
    value: personalInfo.location,
    link: '#'
  }
];
---

<section id="contact" class="py-20 relative">
  <div class="container">
    <!-- Section Header -->
    <div class="scroll-reveal mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Me Contacter</h2>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl">
        Vous avez un projet ou une question ? N'hésitez pas à me contacter.
      </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Left Column - Contact Info -->
      <div class="scroll-reveal space-y-8">
        <!-- Contact Cards -->
        <div class="space-y-6">
          {contactInfo.map(info => (
            <a
              href={info.link}
              class="group p-6 rounded-lg glass card-hover flex items-start gap-4"
            >
              <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)]/20 group-hover:scale-110 group-hover:text-[var(--color-primary)] transition-all">
                <span set:html={createIconSvg(info.icon, 'w-6 h-6')}></span>
              </div>
              <div class="flex-1">
                <p class="text-sm text-[var(--color-text-muted)] uppercase tracking-widest font-semibold mb-1">
                  {info.label}
                </p>
                <p class="text-lg font-semibold group-hover:text-[var(--color-primary)] transition-colors">
                  {info.value}
                </p>
              </div>
            </a>
          ))}
        </div>

        <!-- Social Links -->
        <div class="pt-6 border-t border-[var(--color-border)]">
          <p class="text-sm text-[var(--color-text-muted)] uppercase tracking-widest font-semibold mb-6">
            Mes profils
          </p>
          <div class="grid grid-cols-2 gap-4">
            {socialLinks.map(link => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                title={link.label}
                class="group p-4 rounded-lg glass card-hover flex items-center justify-center gap-2 hover:bg-[var(--color-primary)] hover:text-white transition-all"
              >
                <span set:html={createIconSvg(link.icon, 'w-5 h-5')}></span>
                <span class="font-semibold text-sm">{link.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right Column - Contact Form -->
      <div class="scroll-reveal">
        <form id="contact-form" class="space-y-6 p-8 rounded-lg glass">
          <!-- Name Field -->
          <div>
            <label for="name" class="block text-sm font-semibold mb-2 uppercase tracking-widest text-[var(--color-text-muted)]">
              Votre Nom
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text)] placeholder-[var(--color-text-muted-light)] focus:border-[var(--color-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all"
              placeholder="Votre nom complet"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label for="email" class="block text-sm font-semibold mb-2 uppercase tracking-widest text-[var(--color-text-muted)]">
              Votre Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text)] placeholder-[var(--color-text-muted-light)] focus:border-[var(--color-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all"
              placeholder="votre@email.com"
            />
          </div>

          <!-- Subject Field -->
          <div>
            <label for="subject" class="block text-sm font-semibold mb-2 uppercase tracking-widest text-[var(--color-text-muted)]">
              Sujet
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text)] placeholder-[var(--color-text-muted-light)] focus:border-[var(--color-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all"
              placeholder="Sujet de votre message"
            />
          </div>

          <!-- Message Field -->
          <div>
            <label for="message" class="block text-sm font-semibold mb-2 uppercase tracking-widest text-[var(--color-text-muted)]">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] text-[var(--color-text)] placeholder-[var(--color-text-muted-light)] focus:border-[var(--color-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/20 transition-all resize-none"
              placeholder="Votre message..."
            ></textarea>
          </div>

          <!-- Honeypot (anti-spam) -->
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_subject" value="Nouveau message depuis votre portfolio" />

          <!-- Submit Button -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full px-6 py-3 rounded-lg bg-[var(--color-primary)] text-white font-bold hover:bg-[var(--color-primary-light)] transition-all hover:shadow-lg flex items-center justify-center gap-2 group disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="submit-text">Envoyer le message</span>
            <span id="submit-icon" set:html={createIconSvg('Send', 'w-5 h-5 group-hover:translate-x-1 transition-transform')}></span>
            <span id="submit-spinner" class="hidden">
              <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div
    id="toast"
    class="fixed bottom-6 right-6 z-50 max-w-sm p-6 rounded-lg glass backdrop-blur-xl border border-[var(--color-border)] shadow-2xl transform -translate-y-full opacity-0 transition-all duration-300 pointer-events-none"
  >
    <div id="toast-icon" class="mb-3 text-3xl"></div>
    <p id="toast-message" class="text-[var(--color-text)] font-semibold"></p>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text');
    const submitIcon = document.getElementById('submit-icon');
    const submitSpinner = document.getElementById('submit-spinner');
    const toast = document.getElementById('toast');
    const toastIcon = document.getElementById('toast-icon');
    const toastMessage = document.getElementById('toast-message');

    function showToast(message, isSuccess = true) {
      toastMessage.textContent = message;
      if (isSuccess) {
        toastIcon.innerHTML = '<svg viewBox="0 0 24 24" class="w-8 h-8 text-[var(--color-success)]" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
      } else {
        toastIcon.innerHTML = '<svg viewBox="0 0 24 24" class="w-8 h-8 text-[var(--color-danger)]" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
      }
      
      toast.classList.remove('-translate-y-full', 'opacity-0', 'pointer-events-none');
      setTimeout(() => {
        toast.classList.add('-translate-y-full', 'opacity-0', 'pointer-events-none');
      }, 4000);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Disable button and show spinner
      submitBtn.disabled = true;
      submitText.textContent = 'Envoi en cours...';
      submitIcon.classList.add('hidden');
      submitSpinner.classList.remove('hidden');

      const formData = new FormData(form);

      try {
        const response = await fetch('https://formsubmit.co/ajax/you2007b@gmail.com', {
          method: 'POST',
          body: formData
        });

        if (response.ok) {
          showToast('Message envoyé avec succès ! 🎉', true);
          form.reset();
          submitBtn.disabled = false;
          submitText.textContent = 'Envoyer le message';
          submitIcon.classList.remove('hidden');
          submitSpinner.classList.add('hidden');
        } else {
          showToast('Une erreur s\'est produite. Veuillez réessayer.', false);
          submitBtn.disabled = false;
          submitText.textContent = 'Envoyer le message';
          submitIcon.classList.remove('hidden');
          submitSpinner.classList.add('hidden');
        }
      } catch (error) {
        showToast('Erreur lors de l\'envoi. Veuillez réessayer.', false);
        submitBtn.disabled = false;
        submitText.textContent = 'Envoyer le message';
        submitIcon.classList.remove('hidden');
        submitSpinner.classList.add('hidden');
      }
    });
  });
</script>

<style is:global>
  /* Input focus styles for light theme */
  html[data-theme='light'] input:focus-visible,
  html[data-theme='light'] textarea:focus-visible {
    --color-primary: #2563eb;
  }
</style>
